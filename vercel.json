{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/health", "destination": "/api/index.py" },
    { "source": "/css/(.*)", "destination": "/web/css/$1" },
    { "source": "/js/(.*)", "destination": "/web/js/$1" },
    { "source": "/cases/(.*)", "destination": "/web/cases/$1" },
    { "source": "/icons/(.*)", "destination": "/web/icons/$1" },
    { "source": "/i18n.js", "destination": "/web/i18n.js" },
    { "source": "/admin", "destination": "/web/admin/index.html" },
    { "source": "/admin/", "destination": "/web/admin/index.html" },
    { "source": "/(.*)", "destination": "/web/index.html" }
  ]
}
